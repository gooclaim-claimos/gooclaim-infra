# =============================================================================
# Gooclaim — dev environment variables TEMPLATE
# =============================================================================
#
# COPY THIS FILE to `terraform.tfvars` (gitignored) before running terraform.
# `terraform.tfvars` itself is gitignored — never commit real values.
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # edit terraform.tfvars if you need overrides
#   terraform plan
#
# All values below are the dev defaults — defined in variables.tf.
# Override here only if you need to deviate from dev baseline.
# =============================================================================

environment           = "dev"
resource_group_name   = "gooclaim-rg-dev"
location              = "centralindia"

# AKS sizing (smallest sensible for dev)
kubernetes_version    = "1.29.0"
system_node_count     = 2
system_node_min_count = 2
system_node_max_count = 4
system_node_vm_size   = "Standard_D2s_v3"

# Tags applied to all resources
tags = {
  env           = "dev"
  owner         = "gooclaim"
  "cost-center" = "pilot"
  "managed-by"  = "terraform"
}
